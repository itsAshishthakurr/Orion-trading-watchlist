{
  "manifest_version": 3,
  "name": "ORION Watchlist",
  "version": "3.0",
  "description": "Advanced TradingView Side Panel Watchlist Manager",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "sidePanel",
    "contextMenus"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://*.tradingview.com/*",
    "<all_urls>"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open ORION",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  }
}